[Unit]
Description=Lumen occupancy previous-day report
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/lumen-bots
EnvironmentFile=/etc/lumen-bots/business360.env
ExecStart=/usr/bin/python3 /opt/lumen-bots/business360_daily_bot.py --occupancy-yesterday-once
