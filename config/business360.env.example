# Telegram bot token for LumenBot
BUSINESS360_BOT_TOKEN=
# Owner/admin Telegram chat id
BUSINESS360_CHAT_ID=
# Runtime state directory, e.g. /var/lib/lumen-bots
BUSINESS360_STATE_DIR=/var/lib/lumen-bots
# Optional raw cookie value or path to cookie file
BUSINESS360_COOKIE=
BUSINESS360_COOKIE_FILE=/var/lib/lumen-bots/business360.cookie
